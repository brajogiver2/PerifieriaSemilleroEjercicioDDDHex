<configuration>

    <appender name="JSON"
              class="ch.qos.logback.core.ConsoleAppender">

        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <customFields>{"service":"skeleton-hexagonal"}</customFields>
        </encoder>

    </appender>

    <root level="INFO">
        <appender-ref ref="JSON"/>
    </root>

</configuration>